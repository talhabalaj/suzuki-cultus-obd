<?xml version="1.0" encoding="utf-8"?>
<!--
  RealDash Custom Connection — Suzuki Cultus 2016 PK (K-Line KWP2000)
  Adapter : IOS-Vlink BLE (ELM327 v2.3)
  Protocol: ISO 14230-4 KWP fast init, ECU address 0x11

  HOW TO USE IN REALDASH:
    1. Connections → Add → RealDash Custom (BLE)
    2. Select device: IOS-Vlink
    3. Service UUID  : e7810a71-73ae-499d-8c15-faa9aef0c3f2
    4. Write UUID    : bef8d6c9-9c21-4c9e-b632-bd58c1009f9f
    5. Notify UUID   : bef8d6c9-9c21-4c9e-b632-bd58c1009f9f
    6. Select this XML file

  BYTE MAP (response to "21 00", after stripping 61 00 header):
    b[14]     Coolant temp    (V - 40 = °C)
    b[20:21]  RPM             ((B0<<8|B1) * 0.25)
    b[22]     Vehicle speed   (km/h)
    b[24]     Intake air temp (V - 40 = °C)
    b[27]     Throttle pos    (V * 0.392 = %)
    b[41]     Baro pressure   (V * 0.5 = kPa)
    b[49]     Battery voltage (V * 0.0784 = V)

  NOTE: offsets below are into the FULL response (include 61 00 prefix = +2)
-->
<RealDashCAN version="2">
  <frames>

    <!-- ═══════════════════════════════════════════════════════════════
         FRAME 0 — ELM327 + ECU initialisation (sent ONCE on connect)
         All AT commands as ASCII bytes + CR (0x0D) per command.
         Delays between commands are handled by ELM327 prompt response.
         ═══════════════════════════════════════════════════════════════ -->
    <frame id="0" name="ELM327_Init" length="0"
           writeEnabled="true" writeOnlyOnce="true">
      <writeData>
        41 54 5A 0D
        41 54 45 30 0D
        41 54 4C 30 0D
        41 54 53 30 0D
        41 54 48 30 0D
        41 54 41 4C 0D
        41 54 49 42 31 30 0D
        41 54 4B 57 30 0D
        41 54 53 57 30 30 0D
        41 54 41 54 30 0D
        41 54 43 41 46 31 0D
        41 54 43 46 43 31 0D
        41 54 46 43 53 4D 30 0D
        41 54 54 50 35 0D
        41 54 53 48 20 38 31 20 31 31 20 46 31 0D
        41 54 53 54 20 31 39 0D
        41 54 46 49 0D
        41 54 4B 57 0D
        33 45 0D
      </writeData>
      <!--
        Decoded:
          ATZ\r
          ATE0\r
          ATL0\r
          ATS0\r       (spaces off — critical!)
          ATH0\r
          ATAL\r
          ATIB10\r
          ATKW0\r
          ATSW00\r
          ATAT0\r
          ATCAF1\r
          ATCFC1\r
          ATFCSM0\r
          ATTP5\r      (KWP fast init protocol)
          ATSH 81 11 F1\r   (header: fmt=0x81, ECU=0x11, tester=0xF1)
          ATST 19\r    (100ms timeout)
          ATFI\r       (fast init — wakes engine ECU)
          ATKW\r       (read keyword bytes)
          3E\r         (TesterPresent)
      -->
    </frame>

    <!-- ═══════════════════════════════════════════════════════════════
         FRAME 1 — TesterPresent keepalive (every 2000ms)
         Must be sent to keep ECU session alive.
         ═══════════════════════════════════════════════════════════════ -->
    <frame id="1" name="TesterPresent" length="0"
           writeEnabled="true" writeInterval="2000">
      <writeData>33 45 0D</writeData>
      <!-- 3E\r = TesterPresent, ECU replies 7E -->
    </frame>

    <!-- ═══════════════════════════════════════════════════════════════
         FRAME 2 — Engine data block (every 300ms)
         Request : 21 00\r  → ASCII: 32 31 20 30 30 0D
         Response: 61 00 [65 data bytes]  (67 bytes total)

         All offsets are into the FULL response including 61 00 header.
         Data bytes start at offset 2.
         ═══════════════════════════════════════════════════════════════ -->
    <frame id="2" name="Engine_Data" length="67"
           writeEnabled="true" writeInterval="300">
      <writeData>32 31 20 30 30 0D</writeData>
      <!-- 21 00\r -->

      <!-- RPM — bytes [22:23] big-endian, × 0.25 -->
      <value name="RPM"
             units="rpm"
             targetId="31"
             offset="22"
             length="2"
             endian="big"
             conversion="V*0.25"/>

      <!-- Coolant Temperature — byte [16], V-40 = °C -->
      <value name="Coolant Temperature"
             units="C"
             targetId="36"
             offset="16"
             length="1"
             conversion="V-40"/>

      <!-- Vehicle Speed — byte [24], raw km/h -->
      <value name="Vehicle Speed"
             units="km/h"
             targetId="39"
             offset="24"
             length="1"
             conversion="V"/>

      <!-- Throttle Position — byte [29], V × 0.392 = % -->
      <value name="Throttle Position"
             units="%"
             targetId="33"
             offset="29"
             length="1"
             conversion="V*0.392"/>

      <!-- Intake Air Temperature — byte [26], V-40 = °C -->
      <value name="Intake Air Temp"
             units="C"
             targetId="37"
             offset="26"
             length="1"
             conversion="V-40"/>

      <!-- Barometric Pressure — byte [43], V × 0.5 = kPa -->
      <value name="Barometric Pressure"
             units="kPa"
             targetId="42"
             offset="43"
             length="1"
             conversion="V*0.5"/>

      <!-- Battery Voltage — byte [51], V × 0.0784 = V -->
      <value name="Battery Voltage"
             units="V"
             targetId="14"
             offset="51"
             length="1"
             conversion="V*0.0784"/>

      <!-- Engine Load — byte [15], V × 100/255 = % -->
      <value name="Engine Load"
             units="%"
             targetId="34"
             offset="15"
             length="1"
             conversion="V*0.392157"/>

      <!-- Ignition Advance — byte [25], V-64 = degrees -->
      <value name="Ignition Advance"
             units="deg"
             targetId="45"
             offset="25"
             length="1"
             conversion="V-64"/>

    </frame>

  </frames>
</RealDashCAN>

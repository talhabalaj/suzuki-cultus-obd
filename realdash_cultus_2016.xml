<?xml version="1.0" encoding="utf-8"?>
<!--
  RealDash OBD2 Custom Connection — Suzuki Cultus 2016 PK (K-Line KWP2000)
  Adapter : IOS-Vlink BLE (ELM327 v2.3)
  Protocol: ISO 14230-4 KWP fast init, ECU address 0x11

  CONNECTION TYPE IN REALDASH: ELM327 (BLE)
  To import: Connections → tap your ELM327 connection → Select Vehicle
             → scroll to "Custom Channel Description File" → pick this file

  RESPONSE LAYOUT (rawReply="true"):
    B0  = 0x61  (response service ID = request 0x21 + 0x40)
    B1  = 0x00  (local ID echo)
    B2  = data[0] ...  B66 = data[64]

  Offsets below: Bx where x = data_byte_index + 2
-->
<OBD2>

  <init>
    <!-- ELM327 reset — ate0/atl0/ats0 MUST stay for RealDash to parse replies -->
    <command send="atz"></command>
    <command send="ate0"></command>
    <command send="atl0"></command>
    <command send="ats0"></command>
    <command send="ath0"></command>

    <!-- KWP2000 specific flags (from SZ Viewer APK decompilation) -->
    <command send="atal"></command>     <!-- allow long messages (>7 bytes) -->
    <command send="atib10"></command>   <!-- K-Line baud 10400 -->
    <command send="atkw0"></command>    <!-- skip keyword byte validation -->
    <command send="atsw00"></command>   <!-- wakeup interval off -->
    <command send="atat0"></command>    <!-- adaptive timing off -->
    <command send="atcaf1"></command>
    <command send="atcfc1"></command>
    <command send="atfcsm0"></command>

    <!-- KWP fast init sequence -->
    <command send="attp5"></command>           <!-- ISO 14230-4 KWP fast init -->
    <command send="atsh 81 11 f1"></command>   <!-- fmt=0x81, ECU=0x11, tester=0xF1 -->
    <command send="atst 19"></command>          <!-- 100ms timeout -->
    <command send="atfi"></command>             <!-- fast init — wakes ECU -->
    <command send="atkw"></command>             <!-- read keyword bytes -->
    <command send="3e"></command>               <!-- TesterPresent — start session -->
  </init>

  <rotation>

    <!-- TesterPresent keepalive — ECU drops session after ~2s without this -->
    <command send="3e" skipCount="0" keepInRotation="true"
             name="Cultus: TesterPresent"></command>

    <!-- ═══════════════════════════════════════════════════════════
         Engine data block — service 0x21, local ID 0x00
         Request : 21 00
         Response: 61 00 + 65 data bytes (67 bytes total)
         rawReply="true": B0=0x61, B1=0x00, data starts at B2
         ═══════════════════════════════════════════════════════════ -->
    <command send="21 00" skipCount="0" rawReply="true" keepInRotation="true">
      <values>

        <!-- ── Core ────────────────────────────────────────────── -->

        <!-- RPM  data[20:21] → B22,B23  ×0.25 -->
        <value targetId="37"
               conversion="(B22*256+B23)*0.25"
               name="Cultus: RPM"></value>

        <!-- Coolant Temperature  data[14] → B16  V-40=°C -->
        <value targetId="36"
               units="C"
               conversion="B16-40"
               name="Cultus: Coolant Temp"></value>

        <!-- Vehicle Speed  data[22] → B24  raw km/h -->
        <value targetId="39"
               units="km/h"
               conversion="B24"
               name="Cultus: Speed"></value>

        <!-- Throttle Position  data[27] → B29  V×0.392=% -->
        <value targetId="33"
               units="%"
               conversion="B29*0.392"
               name="Cultus: TPS"></value>

        <!-- Intake Air Temperature  data[24] → B26  V-40=°C -->
        <value targetId="38"
               units="C"
               conversion="B26-40"
               name="Cultus: IAT"></value>

        <!-- Barometric Pressure  data[41] → B43  V×0.5=kPa → ×0.05=bar -->
        <value targetId="42"
               units="bar"
               conversion="B43*0.05"
               name="Cultus: Baro Pressure"></value>

        <!-- Battery Voltage  data[49] → B51  V×0.0784=V -->
        <value targetId="14"
               conversion="B51*0.0784"
               name="Cultus: Battery Voltage"></value>

        <!-- ── Engine ──────────────────────────────────────────── -->

        <!-- Engine Load  data[13] → B15  V×100/255=% -->
        <value targetId="34"
               units="%"
               conversion="B15*0.392157"
               name="Cultus: Engine Load"></value>

        <!-- Ignition Advance  data[23] → B25  V-64=° BTDC -->
        <value targetId="45"
               conversion="B25-64"
               name="Cultus: Ignition Advance"></value>

        <!-- Desired Idle Speed  data[35] → B37  ×10=RPM (approx) -->
        <value conversion="B37*10"
               name="Cultus: Desired Idle RPM"></value>

        <!-- ── Fuel / Injection ────────────────────────────────── -->

        <!-- Injector Pulse Width  data[37:38] → B39,B40  ×0.256=ms
             This is the closest proxy to fuel consumption rate.
             Higher value = more fuel being injected per cycle.
             Fuel economy degrades as this rises at a given RPM/speed. -->
        <value targetId="59"
               conversion="(B39*256+B40)*0.256"
               name="Cultus: Injector PW (ms)"></value>

        <!-- Fuel Pulse Control 1  data[11] → B13  (raw) -->
        <value conversion="B13"
               name="Cultus: Fuel Control 1 (raw)"></value>

        <!-- Fuel Pulse Control 2  data[12] → B14  (raw) -->
        <value conversion="B14"
               name="Cultus: Fuel Control 2 (raw)"></value>

        <!-- ── O2 / Fuel Trim ──────────────────────────────────── -->

        <!-- O2 Sensor Voltage  data[29] → B31  ×0.0196≈0–5V
             <0.45V = lean, >0.45V = rich -->
        <value targetId="0"
               conversion="B31*0.0196"
               name="Cultus: O2 Sensor (V)"></value>

        <!-- Short-Term Fuel Trim  data[30] → B32  V×0.78-100=%
             0% = no correction, negative = lean correction, positive = rich -->
        <value targetId="92"
               conversion="B32*0.78-100"
               name="Cultus: STFT (%)"></value>

        <!-- ── Air ─────────────────────────────────────────────── -->

        <!-- Air Flow  data[25] → B27  (raw byte, unit TBD) -->
        <value conversion="B27"
               name="Cultus: Air Flow (raw)"></value>

        <!-- ── Idle Air Control ─────────────────────────────────── -->

        <!-- IAC Position  data[42] → B44  V×0.392=% -->
        <value conversion="B44*0.392"
               name="Cultus: IAC Position (%)"></value>

        <!-- IAC Flow  data[43] → B45  (raw) -->
        <value conversion="B45"
               name="Cultus: IAC Flow (raw)"></value>

      </values>
    </command>

  </rotation>

</OBD2>
